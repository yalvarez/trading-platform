# ============================================================
# TRADING PLATFORM - CONFIGURACION DE EJEMPLO
# Copiar este archivo a .env y rellenar con valores reales.
# NUNCA commitear el archivo .env al repositorio.
# ============================================================

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Telegram API ---
TG_API_ID=YOUR_TELEGRAM_API_ID
TG_API_HASH=YOUR_TELEGRAM_API_HASH
TG_PHONE=+1234567890
TELEGRAM_INGESTOR_URL=http://telegram_ingestor:8000

# API key para el endpoint /notify (generar con: openssl rand -hex 32)
NOTIFY_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Chat ID para pruebas (ID numerico de Telegram)
TG_TEST_CHAT_ID=YOUR_CHAT_ID

# --- Logging ---
LOG_LEVEL=INFO

# --- Ventanas de trading (formato HH:MM-HH:MM, separadas por coma) ---
TRADING_WINDOWS=00:00-23:59

# --- Configuracion de canales y parsers (JSON) ---
# Formato: {"CHANNEL_ID": ["parser1", "parser2"], ...}
# CHANNELS_CONFIG_JSON={}

# --- Stop Loss por defecto ---
DEFAULT_SL_XAUUSD_PIPS=60
DEFAULT_SL_PIPS=100

# --- Entry range gate ---
ENTRY_WAIT_SECONDS=90
ENTRY_POLL_MS=200
ENTRY_BUFFER_POINTS=1.5

# --- Cuentas MT5 (si no se usa base de datos) ---
# ACCOUNTS_JSON=[]

# --- Advanced Trading Features ---
DEDUP_TTL_SECONDS=120
ENABLE_NOTIFICATIONS=true
ENABLE_ADVANCED_TRADE_MGMT=true

# --- Take Profit Configuration (%) ---
SCALP_TP1_PERCENT=50
SCALP_TP2_PERCENT=80
LONG_TP1_PERCENT=50
LONG_TP2_PERCENT=80

# --- Breakeven Settings ---
ENABLE_BREAKEVEN=true
BREAKEVEN_OFFSET_PIPS=1

# --- Trailing Stop Settings ---
ENABLE_TRAILING=true
TRAILING_ACTIVATION_PIPS=20
TRAILING_STOP_PIPS=15

# --- Addon Entry Settings ---
ENABLE_ADDON=true
ADDON_MAX_COUNT=1
ADDON_LOT_FACTOR=0.5

# --- Scaling ---
SCALING_TRAMO_PIPS=40
SCALING_PERCENT_PER_TRAMO=25

# --- Admin API ---
# DEBE cambiarse en produccion. No usar valores por defecto.
ADMIN_USER=CHANGE_ME
ADMIN_PASS=CHANGE_ME_use_a_strong_password

# --- Base de datos de configuracion ---
CONFIG_DB_URL=postgresql://trading_user:CHANGE_ME@postgres:5432/trading_config

# --- MT5 web UI (para VNC) ---
MT5_WEB_USER=CHANGE_ME
MT5_WEB_PASS=CHANGE_ME_strong_password
